PROJECT_NAME           = openreview
PROJECT_BRIEF          = AI-assisted pull request review automation
PROJECT_NUMBER         = 0.1.0
OUTPUT_DIRECTORY       = build/docs/doxygen
CREATE_SUBDIRS         = NO
ALLOW_UNICODE_NAMES    = YES
OUTPUT_LANGUAGE        = English

INPUT                  = README.md docs src/openreview
INPUT_ENCODING         = UTF-8
FILE_PATTERNS          = *.md *.py
RECURSIVE              = YES
EXCLUDE                = src/openreview/__pycache__ tests .venv build

USE_MDFILE_AS_MAINPAGE = README.md
EXTENSION_MAPPING      = py=Python
MARKDOWN_SUPPORT       = YES
TOC_INCLUDE_HEADINGS   = 2
AUTOLINK_SUPPORT       = YES
PYTHON_DOCSTRING       = YES

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = NO
EXTRACT_LOCAL_CLASSES  = YES
EXTRACT_LOCAL_METHODS  = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO

GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_FILE_EXTENSION    = .html
HTML_COLORSTYLE        = AUTO_LIGHT
GENERATE_TREEVIEW      = YES
FULL_SIDEBAR           = YES

GENERATE_LATEX         = YES
LATEX_OUTPUT           = latex
USE_PDFLATEX           = YES
LATEX_BATCHMODE        = YES
LATEX_SOURCE_CODE      = YES

GENERATE_XML           = NO
GENERATE_RTF           = NO
GENERATE_MAN           = NO

SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES
VERBATIM_HEADERS       = NO

HAVE_DOT               = YES
CLASS_DIAGRAMS         = YES
DOT_IMAGE_FORMAT       = svg
INTERACTIVE_SVG        = YES
CALL_GRAPH             = NO
CALLER_GRAPH           = NO
DOT_MULTI_TARGETS      = YES

QUIET                  = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
WARN_AS_ERROR          = NO